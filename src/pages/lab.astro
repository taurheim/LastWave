---
import BaseLayout from '../layouts/BaseLayout.astro';
import SliceLab from '../components/lab/SliceLab';
---

<BaseLayout title="LastWave - Label Positioning Lab">
  <div class="text-center mb-6">
    <h2 class="font-display text-2xl text-lw-heading mb-2">
      Label Positioning Lab
      {import.meta.env.DEV && (
        <sub class="ml-1 text-xs font-mono tracking-widest text-cyan-400 animate-pulse drop-shadow-[0_0_6px_rgba(34,211,238,0.8)]">DEV</sub>
      )}
    </h2>
    <p class="text-sm text-lw-muted max-w-xl mx-auto">
      Each card shows a stream slice with text positioned by the algorithm.
      The filled area shows the actual Bezier curve; dashed lines show the straight-line model the algorithm uses.
    </p>
  </div>
  <SliceLab client:load />
</BaseLayout>
