---
import { ClientRouter } from 'astro:transitions';
import ErrorToast from '@/components/ErrorToast';

interface Props {
  title?: string;
}

const { title = 'LastWave' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Graph your music listening history with LastWave" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
    <style>
      @font-face {
        font-family: 'Super Arena';
        src: url('/fonts/SuperArena.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
      :root {
        --lw-bg: 245 223 197;
        --lw-surface: 255 255 255;
        --lw-border: 61 12 17;
        --lw-accent: 196 40 40;
        --lw-accent-dim: 163 33 33;
        --lw-teal: 212 168 67;
        --lw-cyan: 139 107 139;
        --lw-muted: 139 115 85;
        --lw-text: 61 28 30;
        --lw-heading: 45 10 16;
        --lw-body-bg: #f5dfc5;
      }
      body {
        background: var(--lw-body-bg);
      }
      .nav-link {
        position: relative;
        transition: color 0.3s;
      }
      .nav-link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 1px;
        background: rgb(var(--lw-accent));
        transition: width 0.3s ease;
      }
      .nav-link:hover::after {
        width: 100%;
      }
    </style>
  </head>
  <body class="min-h-screen pb-3 font-body text-lw-text lg:pb-6">
    <!-- Decorative background waves -->
    <svg
      class="fixed inset-0 -z-10 h-full w-full"
      viewBox="0 0 1440 900"
      preserveAspectRatio="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <!-- Orange — big sweeping band from left up to top-right -->
      <path
        d="M-100,500 C100,420 300,300 500,220 C700,140 900,60 1100,20 C1300,-20 1440,-10 1540,0
           L1540,160 C1440,140 1300,120 1100,180 C900,240 700,340 500,420 C300,500 100,580 -100,650 Z"
        fill="#E8842A" opacity="0.6"
      />
      <!-- Red/crimson — flows from bottom-left through center-right -->
      <path
        d="M-100,700 C50,620 200,530 400,480 C650,420 850,350 1050,320 C1250,290 1400,300 1540,320
           L1540,480 C1400,450 1250,430 1050,470 C850,510 650,580 400,640 C200,700 50,770 -100,850 Z"
        fill="#C13B2A" opacity="0.55"
      />
      <!-- Green — wide band from lower-left sweeping to right -->
      <path
        d="M-100,780 C150,710 350,600 580,560 C810,520 1000,490 1200,440 C1350,400 1440,410 1540,430
           L1540,610 C1440,580 1350,560 1200,600 C1000,650 810,700 580,740 C350,780 150,860 -100,950 Z"
        fill="#6B8E3B" opacity="0.55"
      />
      <!-- Blue — flows between green and red -->
      <path
        d="M-100,620 C100,560 280,470 500,430 C720,390 950,380 1150,350 C1300,330 1440,350 1540,370
           L1540,500 C1440,480 1300,460 1150,480 C950,510 720,530 500,570 C280,610 100,690 -100,760 Z"
        fill="#2E6DB4" opacity="0.55"
      />
    </svg>

    <header
      class="pb-1 pt-4 text-center lg:pb-3 lg:pt-10 max-lg:landscape:pb-0 max-lg:landscape:pt-2"
    >
      <h1
        class="font-display text-5xl text-lw-heading lg:text-8xl max-lg:landscape:text-4xl"
        style="text-shadow: 0 2px 8px rgba(245, 223, 197, 0.8);"
      >
        LastWave
      </h1>
    </header>

    <nav class="mb-2 text-center lg:mb-6 max-lg:landscape:mb-1">
      <div
        class="inline-flex items-center gap-4 text-xs uppercase tracking-widest text-lw-muted lg:gap-8 lg:text-sm max-lg:landscape:gap-3"
      >
        <a href="/" id="nav-home-link" class="nav-link hover:text-lw-accent">Home</a>
        <span class="inline-block h-3 w-px bg-lw-border"></span>
        <a href="/gallery" class="nav-link hover:text-lw-accent">Gallery</a>
        <span class="inline-block h-3 w-px bg-lw-border"></span>
        <a href="/about" class="nav-link hover:text-lw-accent">About</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <ErrorToast client:load />

    <footer
      id="site-footer"
      class="mt-4 pb-2 text-center text-xs tracking-wider text-lw-muted/40 lg:mt-6 lg:pb-3"
    >
      <div
        class="mx-auto mb-2 h-px w-12 bg-gradient-to-r from-transparent via-lw-border to-transparent"
      >
      </div>
      LastWave &middot; built by <a
        href="https://savas.ca"
        class="transition-colors hover:text-lw-accent">Niko Savas</a
      >
    </footer>

  </body>
</html>
