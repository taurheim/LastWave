---
import { ClientRouter } from 'astro:transitions';
import ErrorToast from '@/components/ErrorToast';

interface Props {
  title?: string;
}

const { title = 'LastWave' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Graph your music listening history with LastWave" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
    <style>
      @font-face {
        font-family: 'Super Arena';
        src: url('/fonts/SuperArena.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
      :root {
        --lw-bg: 245 223 197;
        --lw-surface: 255 255 255;
        --lw-border: 61 12 17;
        --lw-accent: 196 40 40;
        --lw-accent-dim: 163 33 33;
        --lw-teal: 212 168 67;
        --lw-cyan: 139 107 139;
        --lw-muted: 139 115 85;
        --lw-text: 61 28 30;
        --lw-heading: 45 10 16;
        --lw-body-bg: #f5dfc5;
      }
      body {
        background: var(--lw-body-bg);
      }
      .nav-link {
        position: relative;
        transition: color 0.3s;
      }
      .nav-link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 1px;
        background: rgb(var(--lw-accent));
        transition: width 0.3s ease;
      }
      .nav-link:hover::after {
        width: 100%;
      }
    </style>
  </head>
  <body class="min-h-screen pb-3 font-body text-lw-text lg:pb-6">
    <!-- Decorative background waves — streamgraph-style, asymmetric band widths -->
    <svg
      class="fixed inset-0 -z-10 h-full w-full"
      viewBox="0 0 1440 900"
      preserveAspectRatio="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <!-- Orange (widest band — top) -->
      <path
        d="M-100,100 C100,50 350,-20 600,-70 C850,-90 1100,-100 1540,-100
           L1540,190 C1100,170 850,140 600,170 C350,230 100,330 -100,400 Z"
        fill="#E8842A" opacity="0.6"
      />
      <!-- Red/crimson (medium, bulges in center) -->
      <path
        d="M-100,400 C100,330 350,230 600,170 C850,140 1100,170 1540,190
           L1540,340 C1100,330 850,340 600,360 C350,400 100,490 -100,550 Z"
        fill="#C13B2A" opacity="0.55"
      />
      <!-- Blue (narrows toward right) -->
      <path
        d="M-100,550 C100,490 350,400 600,360 C850,340 1100,330 1540,340
           L1540,460 C1100,440 850,450 600,490 C350,560 100,660 -100,700 Z"
        fill="#2E6DB4" opacity="0.55"
      />
      <!-- Green (widens toward right) -->
      <path
        d="M-100,700 C100,660 350,560 600,490 C850,450 1100,440 1540,460
           L1540,690 C1100,670 850,670 600,700 C350,760 100,840 -100,890 Z"
        fill="#6B8E3B" opacity="0.55"
      />
    </svg>

    <header
      class="pb-1 pt-4 text-center lg:pb-3 lg:pt-10 max-lg:landscape:pb-0 max-lg:landscape:pt-2"
    >
      <h1
        class="font-display text-5xl text-lw-heading lg:text-8xl max-lg:landscape:text-4xl"
        style="text-shadow: 0 2px 8px rgba(245, 223, 197, 0.8);"
      >
        LastWave
      </h1>
    </header>

    <nav class="mb-2 text-center lg:mb-6 max-lg:landscape:mb-1">
      <div
        class="inline-flex items-center gap-4 text-xs uppercase tracking-widest text-lw-muted lg:gap-8 lg:text-sm max-lg:landscape:gap-3"
      >
        <a href="/" id="nav-home-link" class="nav-link hover:text-lw-accent">Home</a>
        <span class="inline-block h-3 w-px bg-lw-border"></span>
        <a href="/gallery" class="nav-link hover:text-lw-accent">Gallery</a>
        <span class="inline-block h-3 w-px bg-lw-border"></span>
        <a href="/about" class="nav-link hover:text-lw-accent">About</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <ErrorToast client:load />

    <footer
      id="site-footer"
      class="mt-4 pb-2 text-center text-xs tracking-wider text-lw-muted/40 lg:mt-6 lg:pb-3"
    >
      <div
        class="mx-auto mb-2 h-px w-12 bg-gradient-to-r from-transparent via-lw-border to-transparent"
      >
      </div>
      LastWave &middot; built by <a
        href="https://savas.ca"
        class="transition-colors hover:text-lw-accent">Niko Savas</a
      >
    </footer>

  </body>
</html>
