---
import { ClientRouter } from 'astro:transitions';
import ErrorToast from '@/components/ErrorToast';

interface Props {
  title?: string;
}

const { title = 'LastWave' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Graph your music listening history with LastWave" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
    <style>
      @font-face {
        font-family: 'Super Arena';
        src: url('/fonts/SuperArena.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
      :root {
        --lw-bg: 245 223 197;
        --lw-surface: 255 255 255;
        --lw-border: 61 12 17;
        --lw-accent: 196 40 40;
        --lw-accent-dim: 163 33 33;
        --lw-teal: 212 168 67;
        --lw-cyan: 139 107 139;
        --lw-muted: 139 115 85;
        --lw-text: 61 28 30;
        --lw-heading: 45 10 16;
        --lw-body-bg: #f5dfc5;
      }
      body {
        background: var(--lw-body-bg);
      }
      .nav-link {
        position: relative;
        transition: color 0.3s;
      }
      .nav-link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 1px;
        background: rgb(var(--lw-accent));
        transition: width 0.3s ease;
      }
      .nav-link:hover::after {
        width: 100%;
      }
    </style>
  </head>
  <body class="min-h-screen pb-3 font-body text-lw-text lg:pb-6">
    <!-- Decorative background waves -->
    <svg
      class="fixed inset-0 -z-10 h-full w-full"
      viewBox="0 0 1440 900"
      preserveAspectRatio="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path
        d="M-50,320 C200,250 400,180 720,220 C1040,260 1250,150 1500,120
           L1500,200 C1250,230 1040,340 720,300 C400,260 200,330 -50,400 Z"
        fill="#2E6DB4" opacity="0.55"
      />
      <path
        d="M-50,420 C200,350 450,290 750,340 C1050,390 1200,270 1500,240
           L1500,330 C1200,360 1050,480 750,430 C450,380 200,440 -50,510 Z"
        fill="#6B8E3B" opacity="0.5"
      />
      <path
        d="M-50,540 C250,470 500,410 780,460 C1060,510 1250,390 1500,360
           L1500,460 C1250,490 1060,610 780,560 C500,510 250,570 -50,640 Z"
        fill="#E8842A" opacity="0.5"
      />
      <path
        d="M-50,660 C200,590 480,530 760,580 C1040,630 1280,520 1500,490
           L1500,590 C1280,620 1040,730 760,680 C480,630 200,690 -50,760 Z"
        fill="#C13B2A" opacity="0.5"
      />
    </svg>

    <header
      class="pb-1 pt-4 text-center lg:pb-3 lg:pt-10 max-lg:landscape:pb-0 max-lg:landscape:pt-2"
    >
      <h1
        class="font-display text-4xl text-lw-heading lg:text-7xl max-lg:landscape:text-3xl"
      >
        LastWave
      </h1>
    </header>

    <nav class="mb-2 text-center lg:mb-6 max-lg:landscape:mb-1">
      <div
        class="inline-flex items-center gap-4 text-xs uppercase tracking-widest text-lw-muted lg:gap-8 lg:text-sm max-lg:landscape:gap-3"
      >
        <a href="/" id="nav-home-link" class="nav-link hover:text-lw-accent">Home</a>
        <span class="inline-block h-3 w-px bg-lw-border"></span>
        <a href="/gallery" class="nav-link hover:text-lw-accent">Gallery</a>
        <span class="inline-block h-3 w-px bg-lw-border"></span>
        <a href="/about" class="nav-link hover:text-lw-accent">About</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <ErrorToast client:load />

    <footer
      id="site-footer"
      class="mt-4 pb-2 text-center text-xs tracking-wider text-lw-muted/40 lg:mt-6 lg:pb-3"
    >
      <div
        class="mx-auto mb-2 h-px w-12 bg-gradient-to-r from-transparent via-lw-border to-transparent"
      >
      </div>
      LastWave &middot; built by <a
        href="https://savas.ca"
        class="transition-colors hover:text-lw-accent">Niko Savas</a
      >
    </footer>

  </body>
</html>
