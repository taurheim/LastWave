---
import { ClientRouter } from 'astro:transitions';
import ErrorToast from '@/components/ErrorToast';

interface Props {
  title?: string;
}

const { title = 'LastWave' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Graph your music listening history with LastWave" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Roboto:wght@100;300;400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      // Apply theme before first paint to avoid flash
      (function() {
        const stored = localStorage.getItem('lw-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
    <style>
      :root {
        --lw-bg: 240 242 245;
        --lw-surface: 255 255 255;
        --lw-border: 200 205 212;
        --lw-accent: 0 105 155;
        --lw-accent-dim: 0 85 128;
        --lw-teal: 176 212 212;
        --lw-cyan: 0 120 122;
        --lw-muted: 70 85 100;
        --lw-text: 30 41 59;
        --lw-heading: 15 23 42;
        --lw-body-bg: #f0f2f5;
        --lw-glow-a: rgba(0,105,155,0.06);
        --lw-glow-b: rgba(0,120,122,0.04);
      }
      .dark {
        --lw-bg: 12 17 23;
        --lw-surface: 20 27 36;
        --lw-border: 30 42 54;
        --lw-accent: 39 170 225;
        --lw-accent-dim: 32 145 190;
        --lw-teal: 47 79 79;
        --lw-cyan: 0 206 209;
        --lw-muted: 122 143 160;
        --lw-text: 226 232 240;
        --lw-heading: 255 255 255;
        --lw-body-bg: #0c1117;
        --lw-glow-a: rgba(39,170,225,0.06);
        --lw-glow-b: rgba(0,206,209,0.04);
      }
      body {
        background: var(--lw-body-bg);
        background-image:
          radial-gradient(ellipse 80% 60% at 50% 0%, var(--lw-glow-a) 0%, transparent 70%),
          radial-gradient(ellipse 60% 40% at 80% 100%, var(--lw-glow-b) 0%, transparent 60%);
      }
      .logo-drift { }
      .nav-link {
        position: relative;
        transition: color 0.3s;
      }
      .nav-link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 1px;
        background: linear-gradient(90deg, var(--lw-accent), var(--lw-cyan));
        transition: width 0.3s ease;
      }
      .nav-link:hover::after { width: 100%; }
    </style>
  </head>
  <body class="font-body text-lw-text min-h-screen pb-16">
    <!-- Theme toggle -->
    <button
      id="theme-toggle"
      class="fixed top-4 left-4 z-50 p-2 rounded-lg text-lw-muted hover:text-lw-accent transition-colors"
      aria-label="Toggle theme"
    >
      <svg id="theme-icon-moon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0112.478 3.68a9.75 9.75 0 109.274 11.322z" />
      </svg>
      <svg id="theme-icon-sun" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1.5M12 19.5V21M4.219 4.219l1.061 1.061M17.72 17.72l1.06 1.06M3 12h1.5M19.5 12H21M4.219 19.781l1.061-1.061M17.72 6.28l1.06-1.06" />
        <circle cx="12" cy="12" r="4" />
      </svg>
    </button>

    <header class="pt-12 md:pt-16 pb-6 text-center">
      <div class="inline-flex items-center gap-4">
